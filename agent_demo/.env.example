# Runtime mode
APP_ENV=development
LOG_LEVEL=INFO

# LLM provider placeholders. Set LLM_PROVIDER=deepseek to use DeepSeek.
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBEDDING_MODEL=

# DeepSeek OpenAI-compatible API placeholders.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# PostgreSQL / PGVector placeholder. Set RAG_PROVIDER=pgvector after schema is ready.
RAG_PROVIDER=memory
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASS=
KNOWLEDGE_SCHEMA=public
KNOWLEDGE_TABLE_NAME=knowledge_chunks

# Chatwoot placeholders. Empty means the demo only returns actions locally.
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=2
CHATWOOT_API_ACCESS_TOKEN=
CHATWOOT_BOT_AGENT_ID=
CHATWOOT_DEFAULT_ASSIGNEE_ID=
CHATWOOT_OPEN_ON_INCOMING=false

# Optional admin backend sync target. Every supported Chatwoot event is forwarded here.
ADMIN_WEBHOOK_URL=
ADMIN_WEBHOOK_TOKEN=

# Dashboard API token. Required for protected dashboard endpoints.
DASHBOARD_API_TOKEN=

# Optional private-note translator for human agents.
TRANSLATION_PRIVATE_NOTE_ENABLED=false
TRANSLATION_PROVIDER=pygtrans
TRANSLATION_TARGET_LANG=zh-CN
TRANSLATION_SKIP_CHINESE=true
TRANSLATION_MIN_TEXT_LENGTH=2
TRANSLATION_OUTGOING_ENABLED=false
TRANSLATION_DEFAULT_USER_LANG=
TRANSLATION_TIMEOUT_SECONDS=8
# Fill this only if Google Translate times out on the server.
# Example: PYGTRANS_PROXY=http://127.0.0.1:7890
PYGTRANS_PROXY=

# Agent behavior
RAG_MIN_CONFIDENCE=0.62
SEMANTIC_CACHE_THRESHOLD=0.95
MAX_CONTEXT_CHUNKS=4
